# ============================================================
# BOOKFLOW BACKEND — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

PORT=5000
NODE_ENV=development

# ── M-Pesa Daraja API ────────────────────────────────────────
# Get these from https://developer.safaricom.co.ke/
MPESA_CONSUMER_KEY=your_mpesa_consumer_key_here
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret_here

# Paybill or Till Number (shortcode)
MPESA_SHORTCODE=174379

# For Lipa Na M-Pesa (STK Push) — get from Safaricom portal
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919

# STK Push callback URL (must be HTTPS, publicly accessible)
# Use ngrok for local dev: https://your-ngrok-id.ngrok-free.app
MPESA_CALLBACK_URL=https://your-domain.com/api/mpesa/callback

# Daraja environment: sandbox | production
MPESA_ENV=sandbox

# ── Security ────────────────────────────────────────────────
# Secret for verifying internal requests (optional)
API_SECRET=your_random_secret_here

# ── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,https://your-frontend-domain.com
