# ============================================================
# BOOKFLOW FRONTEND — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ============================================================

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Paystack (PUBLIC key only — never put secret key here)
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key_here

# Backend API URL (M-Pesa STK Push endpoint)
VITE_API_BASE_URL=http://localhost:5000

# App Meta
VITE_APP_NAME=BookFlow
VITE_APP_URL=http://localhost:3000

# Admin UID (Firebase UID of the platform admin)
VITE_ADMIN_UID=your_firebase_admin_uid_here
